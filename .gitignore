# ── DATA: Exclude everything to prevent PHI/HIPAA leakage ────────────────────
# Exclude all data/ contents recursively, but preserve folder structure
# via .gitkeep files so collaborators can see the expected layout.

data/**
!data/**/.gitkeep
!data/Reminder.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── Local config (API keys, paths) ───────────────────────────────────────────
# DO NOT commit config.py — use config.py.template instead
src/utils/config.py
!src/utils/config.py.template

# ── OS & editor files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
